{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "cronJobs": [
      {
        "name": "sync-espn-data",
        "schedule": "*/30 * * * *",
        "command": "curl -X POST -H \"Authorization: Bearer ${SYNC_SECRET}\" http://localhost:3000/api/sync"
      }
    ]
  }
}
